# AgentFactory Frontend — Environment Variables
# Copy this file to .env and fill in your values.

# ── AI Spec Generation Model
# Provider used to generate agent specs from user ideas.
# Options: groq | openai | anthropic | ollama
MODEL_PROVIDER=groq

# Model name for the selected provider.
# groq:      llama-3.3-70b-versatile | mixtral-8x7b-32768
# openai:    gpt-4o | gpt-4o-mini
# anthropic: claude-sonnet-4-6 | claude-haiku-4-5
# ollama:    llama3.2 | mistral
MODEL_NAME=llama-3.3-70b-versatile

# Optional: override the provider's default API endpoint.
# groq:   https://api.groq.com/openai/v1
# ollama: http://localhost:11434/v1
# Leave empty to use the provider default.
MODEL_BASE_URL=https://api.groq.com/openai/v1

# API key for the model provider.
# groq:      gsk_...
# openai:    sk-...
# anthropic: sk-ant-...
# ollama:    any non-empty string (e.g. "ollama")
MODEL_API_KEY=your_api_key_here

# ── Backend Execution Engine
# URL of the AgentFactory backend (FastAPI).
# Used server-side by the /api/run proxy route — never exposed to the browser.
# Local:      http://localhost:8080
# Production: https://your-backend.choreoapis.dev/agentfactory/backend/v1.0
BACKEND_URL=http://localhost:8080

# AgentFactory Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Only set the key for the provider your agent use.

# LLM Provider API Keys 
# Used when an agent spec sets provider: groq
# Get a free key at: https://console.groq.com/keys

# Select one provider 

GROQ_API_KEY=your_groq_key_here

# Used when an agent spec sets provider: openai
OPENAI_API_KEY=

# Used when an agent spec sets provider: anthropic
ANTHROPIC_API_KEY=

# Used when an agent spec sets provider: google
GOOGLE_API_KEY=

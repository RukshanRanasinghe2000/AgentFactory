# Model Provider 
# ex:- openai | groq | anthropic | ollama
MODEL_PROVIDER=groq

# Model Name 
# ex:- openai:    gpt-4o | gpt-4o-mini
MODEL_NAME=llama-3.3-70b-versatile

# Base URL 
# Leave empty to use the provider's default endpoint
# ex:- groq:   https://api.groq.com/openai/v1
MODEL_BASE_URL=https://api.groq.com/openai/v1

# API Key 
MODEL_API_KEY=your_api_key_here

# Backend URL
# Local:      http://localhost:8080
# Production: https://your-backend.choreoapis.dev/agentfactory/backend/v1.0
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
